APP_NAME=Area Todo API
DEBUG=false
# Use `db` as the host inside the devcontainer; use `localhost` when running locally.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/area_todo
CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=dev-only-change-me-use-32chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRES_SECONDS=86400
